@model DemandaDiaria.Models.SucursalViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Editar</h1>

<h4>Sucursal</h4>
<hr />
<div class="row">
    <div class="col-md-12">
        <form asp-action="EditSucursal">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PlazaId" />

            <partial name="_Sucursal" />

            <div class="form-group mt-2">
                <input type="submit" value="Guardar" class="btn btn-outline-primary" />
                <a asp-action="Details" asp-route-id="@Model.PlazaId" class="btn btn-outline-danger">Regresar</a>
            </div>
        </form>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

